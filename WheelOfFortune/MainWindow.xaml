<Window x:Class="FortuneWheel.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:FortuneWheel.ViewModels"
        Title="🎡 Йобанная рулетка"
        Height="680" Width="950"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
    
    <Window.InputBindings>
        <KeyBinding Key="K"
                    Modifiers="Ctrl+Shift"
                    Command="{Binding SecretCodeCommand}"/>
    </Window.InputBindings>
    
    
    <Window.Resources>
        <vm:BoolToColorConverter x:Key="HighlightConverter"/>
        <vm:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
        <vm:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <TabControl SelectedIndex="{Binding SelectedTabIndex}" Padding="0">

            <!-- ============ ВКЛАДКА 1: РОЗЫГРЫШ ============ -->
            <TabItem Header="🎰 Розыгрыш">
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="18"/>
                        <ColumnDefinition Width="300"/>
                    </Grid.ColumnDefinitions>

                    <!-- ЛЕВАЯ ЧАСТЬ -->
                    <DockPanel Grid.Column="0">
                        <TextBlock DockPanel.Dock="Top"
                                   Text="Сотрудники (отметьте галочками тех, кто в смене):"
                                   FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>

                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                            <CheckBox Content="Показать скрытых сотрудников"
                                      IsChecked="{Binding ShowAllPlayers}"
                                      VerticalAlignment="Center" Margin="0,0,15,0"/>
                        </StackPanel>

                        <ListBox ItemsSource="{Binding Players}"
                                 SelectedItem="{Binding SelectedPlayer}"
                                 HorizontalContentAlignment="Stretch"
                                 BorderBrush="#CCC" BorderThickness="1"
                                 Background="White">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8,6" Margin="0"
                                            BorderBrush="#EEE" BorderThickness="0,0,0,1"
                                            Background="{Binding IsHighlighted, Converter={StaticResource HighlightConverter}}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <CheckBox Grid.Column="0"
                                                      IsChecked="{Binding IsSelected}"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,10,0"
                                                      IsEnabled="{Binding IsActive}"/>

                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontSize="14"
                                                           Foreground="{Binding NameBrush}"/>
                                                <TextBlock Text="{Binding StatusText}" FontSize="12"
                                                           Foreground="Gray" FontStyle="Italic"/>
                                            </StackPanel>

                                            <Border Grid.Column="2"
                                                    Background="#E3F2FD" CornerRadius="10"
                                                    Padding="8,2" VerticalAlignment="Center"
                                                    Margin="0,0,8,0">
                                                <TextBlock FontSize="13" FontWeight="SemiBold"
                                                           Foreground="#1565C0"
                                                           Text="{Binding Coefficient, StringFormat='×{0}'}"/>
                                            </Border>

                                            <Button Grid.Column="3"
                                                    Content="↩ Восстановить"
                                                    Command="{Binding DataContext.RestoreCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                    CommandParameter="{Binding}"
                                                    Padding="6,3" FontSize="11"
                                                    Visibility="{Binding IsActive, Converter={StaticResource InverseBoolToVisibility}}"
                                                    Background="#4CAF50" Foreground="White"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>

                    <!-- ПРАВАЯ ЧАСТЬ -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="➕ Новый сотрудник:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding NewPlayerName, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,6"/>
                        <Button Content="Добавить" Command="{Binding AddCommand}"
                                HorizontalAlignment="Stretch" Margin="0,0,0,18"/>

                        <TextBlock Text="🎯 Выбранный сотрудник:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <Button Content="Скрыть (мягкое удаление)"
                                Command="{Binding SoftDeleteCommand}"
                                HorizontalAlignment="Stretch" Margin="0,0,0,5"
                                Visibility="{Binding SelectedPlayer.IsActive, Converter={StaticResource BoolToVisibility}, FallbackValue=Collapsed}"/>
                        <Button Content="Стереть (жёсткое удаление)"
                                Command="{Binding HardDeleteCommand}"
                                HorizontalAlignment="Stretch" Margin="0,0,0,5"
                                Foreground="#C62828"/>
                        <TextBlock Text="💡 Перед жёстким удалением сделайте экспорт базы"
                                   FontSize="10" Foreground="#888" FontStyle="Italic"
                                   TextWrapping="Wrap" Margin="0,0,0,15"/>

                        <Button Command="{Binding SpinCommand}"
                                Height="70" FontSize="22" FontWeight="Bold"
                                HorizontalAlignment="Stretch" Margin="0,0,0,20">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#FFB300"/>
                                    <Setter Property="Content" Value="🎰 КРУТИТЬ!"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSpinning}" Value="True">
                                            <Setter Property="IsEnabled" Value="False"/>
                                            <Setter Property="Content" Value="⏳ Крутим..."/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Border BorderBrush="#BBB" BorderThickness="1"
                                Background="White" Padding="12" MinHeight="90" CornerRadius="4">
                            <TextBlock Text="{Binding ResultText}"
                                       TextWrapping="Wrap" FontSize="14"/>
                        </Border>

                        <Border Margin="0,18,0,0" Padding="10" Background="#FAFAFA"
                                BorderBrush="#DDD" BorderThickness="1" CornerRadius="3">
                            <StackPanel>
                                <TextBlock Text="{Binding StorageModeText}"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="#2E7D32" Margin="0,0,0,6"/>
                                <TextBlock Text="📂 Папка с данными:" FontSize="11"
                                           Foreground="#666" Margin="0,0,0,3"/>
                                <TextBlock Text="{Binding DatabaseFolder}" FontSize="11"
                                           Foreground="#444" TextWrapping="Wrap"/>
                                <Button Content="Открыть папку"
                                        Command="{Binding OpenDbFolderCommand}"
                                        FontSize="11" Padding="6,3" Margin="0,5,0,0"
                                        HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ============ ВКЛАДКА 2: СТАТИСТИКА ============ -->
            <TabItem Header="📊 Статистика">
                <DockPanel Margin="0,12,0,0">
                    <TextBlock DockPanel.Dock="Top"
                               Text="Статистика розыгрышей по всем сотрудникам"
                               FontWeight="SemiBold" FontSize="14" Margin="0,0,0,10"/>

                    <ListView ItemsSource="{Binding StatsPlayers}"
                              BorderBrush="#CCC" BorderThickness="1"
                              Background="White"
                              AlternationCount="2">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Style.Triggers>
                                    <Trigger Property="ItemsControl.AlternationIndex" Value="0">
                                        <Setter Property="Background" Value="White"/>
                                    </Trigger>
                                    <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                        <Setter Property="Background" Value="#F9F9F9"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Сотрудник" Width="180">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}" FontSize="13"
                                                           Foreground="{Binding NameBrush}"/>
                                                <TextBlock Text="{Binding StatusText}" FontSize="11"
                                                           Foreground="Gray" FontStyle="Italic"
                                                           Margin="5,0,0,0"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Текущий коэф." Width="110"
                                                DisplayMemberBinding="{Binding Coefficient, StringFormat='×{0}'}"/>
                                <GridViewColumn Header="Участий" Width="90"
                                                DisplayMemberBinding="{Binding Participations}"/>
                                <GridViewColumn Header="Проёбов" Width="80"
                                                DisplayMemberBinding="{Binding Wins}"/>
                                <GridViewColumn Header="% проёбов" Width="90"
                                                DisplayMemberBinding="{Binding WinRateText}"/>
                                <GridViewColumn Header="Средний коэф. при проёбе" Width="170"
                                                DisplayMemberBinding="{Binding AvgWinCoefText}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </DockPanel>
            </TabItem>
        </TabControl>
    </Grid>
</Window>